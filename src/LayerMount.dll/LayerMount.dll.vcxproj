<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Debug|ARM64">
      <Configuration>Debug</Configuration>
      <Platform>ARM64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|ARM64">
      <Configuration>Release</Configuration>
      <Platform>ARM64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <ProjectGuid>{6DF4AB1A-9E0C-4A0F-8E3C-D5B7C79F2AA1}</ProjectGuid>
    <RootNamespace>LayerMount</RootNamespace>
    <Keyword>Win32Proj</Keyword>
    <TargetName>LayerMount</TargetName>
  </PropertyGroup>

  <PropertyGroup>
    <!-- Pin OutDir/IntDir to repo-level x64\<Config>\ via
         $(MSBuildThisFileDirectory) so single-project builds
         (msbuild <file>.vcxproj) and solution builds produce the
         same artifacts. Without this, $(SolutionDir) is undefined
         under single-project builds and OutDir falls back to
         $(ProjectDir)x64\<Config>\ — the solution-level copy goes
         stale and test fixtures spawn the wrong binary.
         Each project under src/LayerMount.dll/ needs its own IntDir
         so identical source files (zstd.c, shared impl/*) don't
         collide on .obj filenames during parallel builds. -->
    <OutDir>$(MSBuildThisFileDirectory)..\..\$(Platform)\$(Configuration)\</OutDir>
    <IntDir>$(MSBuildThisFileDirectory)..\..\$(Platform)\$(Configuration)\LayerMount.dll.obj\</IntDir>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Label="Configuration">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <ImportGroup Label="PropertySheets">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props"
            Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')" Label="LocalAppDataPlatform" />
  </ImportGroup>

  <Import Project="LayerMount.sources.props" />
  <Import Project="LayerMount.version.targets" />

  <ItemGroup>
    <!-- DLL-only: ABI shims that emit LM_API-decorated exports. The
         static-lib flavor doesn't define LAYERMOUNT_EXPORTS, so LM_API
         resolves to __declspec(dllimport) there; definitions of such
         functions belong only in the DLL project. -->
    <ClCompile Include="abi\AbiCore.cpp" />
    <ClCompile Include="abi\AbiDiagnostics.cpp" />
    <ClCompile Include="abi\AbiFile.cpp" />
    <ClCompile Include="abi\AbiHostMountPoint.cpp" />
    <ClCompile Include="abi\AbiImage.cpp" />
    <ClCompile Include="abi\AbiPath.cpp" />
    <ClCompile Include="abi\AbiVhd.cpp" />
    <ClCompile Include="abi\AbiVss.cpp" />
  </ItemGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <PreprocessorDefinitions>LAYERMOUNT_EXPORTS;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
    <Link>
      <ModuleDefinitionFile>public\LayerMount.def</ModuleDefinitionFile>
      <AdditionalDependencies>virtdisk.lib;vssapi.lib;ole32.lib;oleaut32.lib;bcrypt.lib;rpcrt4.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <SubSystem>Windows</SubSystem>
    </Link>
    <!-- Enforce on every build that the DLL (a) imports only system and
         CRT libraries from the allowlist in verify-layermount-dll.ps1 (the
         engine is host-agnostic by design) and (b) exposes only C
         symbols (no mangled ?? names). -->
    <PostBuildEvent>
      <Command>call "$(ProjectDir)verify-layermount-dll.cmd" "$(TargetPath)" "$(IntDir)"</Command>
      <Message>Verify LayerMount.dll imports + exports</Message>
    </PostBuildEvent>
  </ItemDefinitionGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />

</Project>
